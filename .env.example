# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production

# ── API ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
# Optional: extra CORS origins by regex. Production auto-allows https://*.vercel.app when unset.
# API_CORS_ORIGIN_REGEX=https://[\w.-]+\.vercel\.app

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dashzen:dashzen@localhost:5432/dashzen

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Object storage (MinIO) ───────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=dashzen

# ── Vector store (Qdrant) ────────────────────────────
QDRANT_URL=http://localhost:6333

# ── LLM ──────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── JWT ──────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
# For RS256, set JWT_ALGORITHM=RS256 and provide PEM keys below instead of JWT_SECRET_KEY
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Auth cookies ─────────────────────────────────────
ACCESS_COOKIE_NAME=dashzen_access_token
REFRESH_COOKIE_NAME=dashzen_refresh_token
ACCESS_COOKIE_PATH=/
REFRESH_COOKIE_PATH=/v1/auth
COOKIE_SAMESITE=lax
# COOKIE_SECURE=true

# ── Rate limiting ────────────────────────────────────
RATE_LIMIT_ENABLED=true
AUTH_LOGIN_RATE_LIMIT=5/minute
AUTH_REGISTER_RATE_LIMIT=10/minute
AUTH_REFRESH_RATE_LIMIT=3/minute
AUTH_VERIFY_RATE_LIMIT=5/minute
AUTH_RESEND_RATE_LIMIT=3/hour

# ── Email ────────────────────────────────────────────
# development: console (prints code to stdout) or smtp (Mailpit — see infra/compose)
# production: EMAIL_BACKEND=smtp with your provider (SES, SendGrid, etc.)
EMAIL_BACKEND=console
EMAIL_FROM=noreply@dashzen.local
EMAIL_VERIFICATION_CODE_TTL_MINUTES=15
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# SMTP (when EMAIL_BACKEND=smtp)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=false
SMTP_SSL=false

# ── Studio (Next.js) ─────────────────────────────────
# Local dev — direct API:
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production Vercel (same-origin proxy):
# NEXT_PUBLIC_API_URL=/api
# API_BACKEND_URL=https://dashzen-api.onrender.com

# ── Production (PaaS) ────────────────────────────────
# Render cookie paths when using Vercel /api proxy:
# REFRESH_COOKIE_PATH=/api/v1/auth
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=true
# See infra/deploy/paas.md

# ── Google OAuth ─────────────────────────────────────
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback
# STUDIO_PUBLIC_URL=http://localhost:3000
# Production callback via Vercel proxy (recommended for cookie domain):
# GOOGLE_REDIRECT_URI=https://your-studio.vercel.app/api/v1/auth/google/callback
# STUDIO_PUBLIC_URL=https://your-studio.vercel.app
OAUTH_STATE_TTL_SECONDS=600

# ── GitHub OAuth ─────────────────────────────────────
GITHUB_OAUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/v1/auth/github/callback
# Production callback via Vercel proxy (recommended for cookie domain):
# GITHUB_REDIRECT_URI=https://your-studio.vercel.app/api/v1/auth/github/callback
