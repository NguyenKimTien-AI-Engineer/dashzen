# ── Production (PaaS Option 3) ───────────────────────
# Vercel (Studio) + Render (API) + Neon (Postgres) + Gemini/OpenRouter (LLM)
# Copy values into each platform's dashboard — never commit real secrets.

APP_ENV=production

# Neon: use asyncpg driver + SSL
# Example: postgresql+asyncpg://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Random 32+ chars (openssl rand -hex 32)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256

# Comma-separated Studio origin(s) — must match Vercel URL exactly
API_CORS_ORIGINS=https://your-studio.vercel.app

# Public API URL (Render service URL, no trailing slash)
API_PUBLIC_URL=https://dashzen-api.onrender.com

# Cross-domain cookies (Studio on Vercel ≠ API on Render)
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# LLM — cloud only on PaaS (no Ollama)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Alternative free tier:
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/free
# OPENROUTER_SITE_URL=https://your-studio.vercel.app
# OPENROUTER_APP_NAME=DashZen Studio

EMAIL_BACKEND=console

# Optional: Upstash Redis (recommended if scaling API beyond 1 instance)
# REDIS_URL=rediss://default:token@host.upstash.io:6379

# Ephemeral disk on Render — avatars reset on redeploy unless you add object storage later
AVATAR_STORAGE_DIR=/app/data/avatars

# ── Vercel (apps/studio) ─────────────────────────────
# NEXT_PUBLIC_API_URL=https://dashzen-api.onrender.com
