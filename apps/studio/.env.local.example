# Local dev — Studio talks directly to the API on :8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production Vercel (set in Vercel dashboard, not here):
# NEXT_PUBLIC_API_URL=/api
# API_BACKEND_URL=https://dashzen-api.onrender.com

# Playwright E2E (optional — npm run test:e2e)
# E2E_EMAIL=
# E2E_PASSWORD=
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true
# NEXT_PUBLIC_GITHUB_OAUTH_ENABLED=true
